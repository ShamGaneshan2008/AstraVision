# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Claude AI (narrative summaries) ──────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── NASA EarthData ────────────────────────────────────────────────────────────
# Register free at https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_USER=
NASA_EARTHDATA_PASS=

# ── ESA Copernicus Dataspace ──────────────────────────────────────────────────
# Register free at https://dataspace.copernicus.eu/
ESA_DATASPACE_USER=
ESA_DATASPACE_PASS=

# ── ML model ─────────────────────────────────────────────────────────────────
# Set USE_ML_MODEL=True after running: python -m model.train
USE_ML_MODEL=False
MODEL_WEIGHTS_PATH=model/weights/change_detector.pkl
MODEL_CONFIDENCE_THRESHOLD=0.45
